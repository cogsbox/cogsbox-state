{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "strict": true,
    "noErrorTruncation": true,
    "lib": ["dom", "dom.iterable", "esnext"]
  },
  "include": ["tests/type-check-plugins.ts", "src/**/*"]
}
